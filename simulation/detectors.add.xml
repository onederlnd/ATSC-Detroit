<!--
    detectors.add.xml
    Inductive loop detectors placed on each approach lane ~10m before
    the stop line. These are what traffic_env.py reads via TraCI to
    build the observation vector.

    One detector per approach (simplified — production systems use
    multiple detectors per lane for queue estimation).

    pos="-10" means 10m before the end of the edge (the stop line).
    freq="1"  means output every 1 simulation second.

    IDs must match DETECTOR_IDS in traffic_env.py:
        det_north_in, det_south_in, det_east_in, det_west_in
-->

<additional>
    <inductionLoop id="det_south_in"
                   lane="A0A1_0"
                   pos="10"
                   freq="1"
                   file="output/det_south_in.xml"/>

    <inductionLoop id="det_north_in"
                   lane="A1A0_0"
                   pos="10"
                   freq="1"
                   file="output/det_north_in.xml"/>

    <inductionLoop id="det_west_in"
                   lane="B0A0_0"
                   pos="10"
                   freq="1"
                   file="output/det_west_in.xml"/>

    <inductionLoop id="det_east_in"
                   lane="A0B0_0"
                   pos="10"
                   freq="1"
                   file="output/det_east_in.xml"/>
</additional>