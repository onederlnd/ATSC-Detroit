<!--
    routes.rou.xml
    Michigan Ave & Livernois, Detroit
    
    Demand calibrated from MDOT AADT estimates for Michigan Ave (~20,000 vpd)
    and Livernois (~10,000 vpd) using standard K-factor (peak hour = 9% of AADT).

    Three demand periods modeled:
        AM Peak  : 7-9 AM   (steps 0-7200)
        Off-Peak : 9AM-4PM  (steps 7200-57600)
        PM Peak  : 4-6 PM   (steps 57600-64800)

    Directional splits:
        Michigan Ave: 55% westbound / 45% eastbound (AM), reversed for PM
        Livernois:    50% northbound / 50% southbound

    Edge IDs match the netgenerate grid network:
        Michigan Ave (E-W): A0B0, B0A0
        Livernois   (N-S): A0A1, A1A0
-->

<routes>

    <!-- Vehicle type — representative Detroit urban mixed fleet -->
    <vType id="car"
           accel="2.6"
           decel="4.5"
           sigma="0.5"
           length="5"
           maxSpeed="13.89"
           color="0.7,0.7,0.7"/>

    <!-- Routes — one per direction through the A0 intersection -->
     <route id="mich_wb" edges="A1A0 A0B0"/>
     <route id="mich_eb" edges="B0A0 A0A1"/>
     <route id="liv_nb"  edges="B1B0 B0A0"/>
     <route id="liv_sb"  edges="A0A1 A1B1"/>
    <!-- ================================================================ -->
    <!-- AM PEAK: 7-9 AM (simulation steps 0-7200)                        -->
    <!-- Michigan Ave: 1800 veh/hr total, 55% WB / 45% EB                 -->
    <!-- Livernois:     900 veh/hr total, 50% NB / 50% SB                 -->
    <!-- ================================================================ -->

    <!-- Michigan Ave westbound AM: 990 veh/hr -->
    <flow id="am_mich_wb"
          type="car"
          route="mich_wb"
          begin="0"
          end="7200"
          vehsPerHour="990"/>

    <!-- Michigan Ave eastbound AM: 810 veh/hr -->
    <flow id="am_mich_eb"
          type="car"
          route="mich_eb"
          begin="0"
          end="7200"
          vehsPerHour="810"/>

    <!-- Livernois northbound AM: 450 veh/hr -->
    <flow id="am_liv_nb"
          type="car"
          route="liv_nb"
          begin="0"
          end="7200"
          vehsPerHour="450"/>

    <!-- Livernois southbound AM: 450 veh/hr -->
    <flow id="am_liv_sb"
          type="car"
          route="liv_sb"
          begin="0"
          end="7200"
          vehsPerHour="450"/>

    <!-- ================================================================ -->
    <!-- OFF-PEAK: 9 AM - 4 PM (simulation steps 7200-57600)              -->
    <!-- Michigan Ave: 800 veh/hr total, 50/50 split                      -->
    <!-- Livernois:    400 veh/hr total, 50/50 split                      -->
    <!-- ================================================================ -->

    <!-- Michigan Ave westbound off-peak: 400 veh/hr -->
    <flow id="op_mich_wb"
          type="car"
          route="mich_wb"
          begin="7200"
          end="57600"
          vehsPerHour="400"/>

    <!-- Michigan Ave eastbound off-peak: 400 veh/hr -->
    <flow id="op_mich_eb"
          type="car"
          route="mich_eb"
          begin="7200"
          end="57600"
          vehsPerHour="400"/>

    <!-- Livernois northbound off-peak: 200 veh/hr -->
    <flow id="op_liv_nb"
          type="car"
          route="liv_nb"
          begin="7200"
          end="57600"
          vehsPerHour="200"/>

    <!-- Livernois southbound off-peak: 200 veh/hr -->
    <flow id="op_liv_sb"
          type="car"
          route="liv_sb"
          begin="7200"
          end="57600"
          vehsPerHour="200"/>

    <!-- ================================================================ -->
    <!-- PM PEAK: 4-6 PM (simulation steps 57600-64800)                   -->
    <!-- Michigan Ave: 2000 veh/hr total, 45% WB / 55% EB (reversed AM)  -->
    <!-- Livernois:    1000 veh/hr total, 50/50 split                     -->
    <!-- ================================================================ -->

    <!-- Michigan Ave westbound PM: 900 veh/hr -->
    <flow id="pm_mich_wb"
          type="car"
          route="mich_wb"
          begin="57600"
          end="64800"
          vehsPerHour="900"/>

    <!-- Michigan Ave eastbound PM: 1100 veh/hr -->
    <flow id="pm_mich_eb"
          type="car"
          route="mich_eb"
          begin="57600"
          end="64800"
          vehsPerHour="1100"/>

    <!-- Livernois northbound PM: 500 veh/hr -->
    <flow id="pm_liv_nb"
          type="car"
          route="liv_nb"
          begin="57600"
          end="64800"
          vehsPerHour="500"/>

    <!-- Livernois southbound PM: 500 veh/hr -->
    <flow id="pm_liv_sb"
          type="car"
          route="liv_sb"
          begin="57600"
          end="64800"
          vehsPerHour="500"/>

</routes>